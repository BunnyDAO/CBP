---
interface Props {
  title: string;
  active?: string;
}
const { title, active = "" } = Astro.props;

const navItems = [
  { href: "/", label: "Dashboard", id: "dashboard" },
  { href: "/targets", label: "Targets", id: "targets" },
  { href: "/history", label: "History", id: "history" },
  { href: "/config", label: "Config", id: "config" },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Gap Signal</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <nav class="w-56 bg-gray-900 border-r border-gray-800 flex flex-col shrink-0">
        <div class="p-5 border-b border-gray-800">
          <h1 class="text-lg font-bold text-white tracking-tight">Gap Signal</h1>
          <p class="text-xs text-gray-500 mt-1">SOL Imbalance Indicator</p>
        </div>
        <ul class="flex-1 py-3">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={`block px-5 py-2.5 text-sm transition-colors ${
                  active === item.id
                    ? "bg-gray-800 text-white border-r-2 border-blue-500"
                    : "text-gray-400 hover:text-white hover:bg-gray-800/50"
                }`}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="p-4 border-t border-gray-800 text-xs text-gray-600">
          SOLUSDT / Binance
        </div>
      </nav>

      <!-- Main content -->
      <main class="flex-1 overflow-auto">
        <div class="max-w-7xl mx-auto p-6">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
